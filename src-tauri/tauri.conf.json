{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuikCap",
  "version": "0.1.0",
  "identifier": "com.brettstewart.quikcap",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "capture",
        "title": "QuikCap",
        "width": 920,
        "height": 620,
        "resizable": true,
        "center": true,
        "visible": false,
        "decorations": false,
        "shadow": true
      },
      {
        "label": "database",
        "title": "QuikCap",
        "width": 1200,
        "height": 750,
        "resizable": true,
        "center": true,
        "visible": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
